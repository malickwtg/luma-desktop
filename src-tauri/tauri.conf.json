{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LUMA",
  "version": "0.1.9",
  "identifier": "es.waytogrow.luma.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/luma-sidecar",
      "binaries/claude"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFGNzhCQURDMkFCRkE1QUMKUldTc3BiOHEzTHA0SDZ1WWt1L2hFbUlaclZIU3dUazBKaGlLUnJPMzlXRG5mcy80M1ZGOG1HUm8K",
      "endpoints": [
        "https://github.com/malickwtg/luma-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
